# PostHog analytics — copy to `.env` and fill in. Expo inlines EXPO_PUBLIC_* vars
# at build time. These are CLIENT keys (safe to ship in the app bundle), but we
# keep them out of git so each environment can point at its own project.
#
# Project API key from PostHog → Project Settings. Without it, analytics no-ops.
EXPO_PUBLIC_POSTHOG_KEY=
# Region host: https://us.i.posthog.com (default) or https://eu.i.posthog.com
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
